CanManager::CanManager() : m_isRunning(false) {}

void CanManager::startSimulation() {
  if (m_isRunning) {
    std::cout << "CAN simulation already running" << std::endl;
    return;
  }

  serverCanScheduler.startCanScheduler();
  serverCanListener.listenCanBus();
  m_isRunning = true;
  std::cout << "CAN simulation started" << std::endl;
}

void CanManager::stopSimulation() {
  m_isRunning = false;
  std::cout << "CAN simulation stopped" << std::endl;
}

bool CanManager::isRunning() const {
  return m_isRunning;
}

std::vector<CanMessageInfo> CanManager::getMessageInfoList() const {
  std::vector<CanMessageInfo> list;

  {%- for message in messages %}
  {
    CanMessageInfo info;
    info.name = "{{ message.name | lower }}";
    info.sender = "{{ message.sender }}";
    info.id = {{ message.id }}U;
    info.dlc = {{ (message.signals | sum(attribute='length') / 8) | int }}U;
    info.cycle_speed = {{ cycle_speed_ms[message.cycle] }}U;
    info.cycle = "{{ message.cycle }}";
    info.critical = {{ "true" if message.critical else "false" }};
    {%- for signal in message.signals %}
    {%- if signal.type == "bitfield" %}
    {
      CanSignalInfo sig{"{{ signal.name | lower }}", {{ signal.length }}U, {{ signal.start_bit }}U, "bitfield", {}};
      {%- for flag in signal.flags %}
      sig.flags.push_back({"{{ flag["name"] | lower }}", {{ flag["length"] }}U, {{ flag["offset"] }}U});
      {%- endfor %}
      info.signals.push_back(sig);
    }
    {%- else %}
    info.signals.push_back({"{{ signal.name | lower }}", {{ signal.length }}U, {{ signal.start_bit }}U, "standard", {}});
    {%- endif %}
    {%- endfor %}
    list.push_back(info);
  }
  {%- endfor %}

  return list;
}

CanMessageInfo CanManager::getMessageInfo(const std::string &message_name) const {
  const auto list = getMessageInfoList();
  for (const auto &info : list) {
    if (info.name == message_name) {
      return info;
    }
  }
  return CanMessageInfo{};
}

